# ── 이 파일을 복사하여 .env.local 을 만들고 실제 값을 채우세요 ──
# cp .env.example .env.local

# PostgreSQL (local docker)
POSTGRES_DB=byby
POSTGRES_USER=byby
POSTGRES_PASSWORD=           # 직접 설정

# Spring Boot
SPRING_PROFILES_ACTIVE=local
BACKEND_PORT=8080
JWT_SECRET=                  # openssl rand -base64 64  (256bit 이상 필수)

# Supabase
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=           # Supabase → Settings → API → anon public
SUPABASE_SERVICE_KEY=        # Supabase → Settings → API → service_role (비공개 유지)

# Claude API (의료 대본 생성)
CLAUDE_API_KEY=              # https://console.anthropic.com

# Frontend
FRONTEND_PORT=3000
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=   # anon key (공개 가능)
